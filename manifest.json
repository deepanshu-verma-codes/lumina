{
    "manifest_version": 3,
    "name": "Lumina",
    "version": "1.0",
    "description": "A Chrome Extension To Take Screenshots",
    "permissions": [
        "activeTab",
        "storage",
        "tabs",
        "desktopCapture",
        "downloads"
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "icons/icon.png",
            "48": "icons/icon.png",
            "128": "icons/icon.png"
        }
    },
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "background": {
        "service_worker": "src/background/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "src/content/overlay.js"
            ],
            "css": [
                "src/content/overlay.css"
            ]
        }
    ],
    "commands": {
        "take-screenshot": {
            "suggested_key": {
                "default": "Alt+Shift+S",
                "mac": "Alt+Shift+S"
            },
            "description": "Take a screenshot"
        },
        "toggle-recording": {
            "suggested_key": {
                "default": "Alt+Shift+R",
                "mac": "Alt+Shift+R"
            },
            "description": "Start/Stop recording"
        }
    },
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ]
}
